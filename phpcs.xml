<?xml version="1.0"?>
<ruleset name="ClientAI WordPress Coding Standards">
    <description>WordPress Coding Standards for ClientAI Plugin</description>

    <!-- Scan all PHP files -->
    <file>./ai-chatbot.php</file>
    <file>./includes/</file>
    <file>./admin/</file>

    <!-- Exclude the vendor directory -->
    <exclude-pattern>./vendor/*</exclude-pattern>

    <!-- Use WordPress Coding Standards -->
    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Docs">
        <!-- File-level docblocks must exist but we won't enforce for all functions -->
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
    </rule>
    <rule ref="WordPress-Extra"/>

    <!-- This is a plugin, not a theme -->
    <config name="text_domain" value="ai-chatbot"/>

    <!-- Minimum PHP version -->
    <config name="minimum_supported_wp_version" value="5.0"/>
</ruleset>